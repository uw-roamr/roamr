prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_raw_hash_set
Description: Abseil raw_hash_set library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_bits = 20260107, absl_common_policy_traits = 20260107, absl_compressed_tuple = 20260107, absl_config = 20260107, absl_container_common = 20260107, absl_container_memory = 20260107, absl_core_headers = 20260107, absl_dynamic_annotations = 20260107, absl_endian = 20260107, absl_function_ref = 20260107, absl_hash = 20260107, absl_hash_function_defaults = 20260107, absl_hash_policy_traits = 20260107, absl_hashtable_control_bytes = 20260107, absl_hashtable_debug_hooks = 20260107, absl_hashtablez_sampler = 20260107, absl_iterator_traits_internal = 20260107, absl_memory = 20260107, absl_meta = 20260107, absl_optional = 20260107, absl_prefetch = 20260107, absl_raw_logging_internal = 20260107, absl_utility = 20260107, absl_weakly_mixed_integer = 20260107
Libs: -L${libdir}  -labsl_raw_hash_set 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
