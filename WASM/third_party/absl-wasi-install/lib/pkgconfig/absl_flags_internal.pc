prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_flags_internal
Description: Abseil flags_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_config = 20260107, absl_fast_type_id = 20260107, absl_flags_commandlineflag = 20260107, absl_flags_commandlineflag_internal = 20260107, absl_flags_config = 20260107, absl_flags_marshalling = 20260107, absl_no_destructor = 20260107, absl_synchronization = 20260107, absl_meta = 20260107, absl_utility = 20260107
Libs: -L${libdir}  -labsl_flags_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
