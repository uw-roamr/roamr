prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_cord_internal
Description: Abseil cord_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_compressed_tuple = 20260107, absl_config = 20260107, absl_container_memory = 20260107, absl_compare = 20260107, absl_core_headers = 20260107, absl_crc_cord_state = 20260107, absl_endian = 20260107, absl_inlined_vector = 20260107, absl_layout = 20260107, absl_raw_logging_internal = 20260107, absl_strings = 20260107, absl_throw_delegate = 20260107, absl_type_traits = 20260107
Libs: -L${libdir}  -labsl_cord_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
