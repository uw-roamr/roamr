prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_random_internal_seed_material
Description: Abseil random_internal_seed_material library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_optional = 20260107, absl_random_internal_fast_uniform_bits = 20260107, absl_raw_logging_internal = 20260107, absl_span = 20260107, absl_strings = 20260107
Libs: -L${libdir}  -labsl_random_internal_seed_material 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
