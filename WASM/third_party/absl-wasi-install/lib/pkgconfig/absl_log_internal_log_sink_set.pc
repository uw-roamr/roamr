prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_log_internal_log_sink_set
Description: Abseil log_internal_log_sink_set library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_cleanup = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_log_internal_config = 20260107, absl_log_internal_globals = 20260107, absl_log_globals = 20260107, absl_log_entry = 20260107, absl_log_severity = 20260107, absl_log_sink = 20260107, absl_no_destructor = 20260107, absl_raw_logging_internal = 20260107, absl_synchronization = 20260107, absl_span = 20260107, absl_strings = 20260107
Libs: -L${libdir}  -labsl_log_internal_log_sink_set 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
