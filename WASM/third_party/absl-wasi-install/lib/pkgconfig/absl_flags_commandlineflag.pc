prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_flags_commandlineflag
Description: Abseil flags_commandlineflag library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_fast_type_id = 20260107, absl_flags_commandlineflag_internal = 20260107, absl_optional = 20260107, absl_strings = 20260107
Libs: -L${libdir}  -labsl_flags_commandlineflag 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
