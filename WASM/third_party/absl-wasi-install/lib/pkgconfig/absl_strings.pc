prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_strings
Description: Abseil strings library
URL: https://abseil.io/
Version: 20260107
Requires: absl_string_view = 20260107, absl_strings_append_and_overwrite = 20260107, absl_strings_internal = 20260107, absl_strings_resize_and_overwrite = 20260107, absl_base = 20260107, absl_bits = 20260107, absl_charset = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_endian = 20260107, absl_int128 = 20260107, absl_iterator_traits_internal = 20260107, absl_memory = 20260107, absl_nullability = 20260107, absl_raw_logging_internal = 20260107, absl_throw_delegate = 20260107, absl_type_traits = 20260107
Libs: -L${libdir}  -labsl_strings 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
