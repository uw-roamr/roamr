prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_int128
Description: Abseil int128 library
URL: https://abseil.io/
Version: 20260107
Requires: absl_compare = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_bits = 20260107
Libs: -L${libdir}  -labsl_int128 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
