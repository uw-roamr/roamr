prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_flags_usage_internal
Description: Abseil flags_usage_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_flags_config = 20260107, absl_flags = 20260107, absl_flags_commandlineflag = 20260107, absl_flags_internal = 20260107, absl_flags_path_util = 20260107, absl_flags_private_handle_accessor = 20260107, absl_flags_program_name = 20260107, absl_flags_reflection = 20260107, absl_strings = 20260107, absl_synchronization = 20260107
Libs: -L${libdir}  -labsl_flags_usage_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
