prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_flags_parse
Description: Abseil flags_parse library
URL: https://abseil.io/
Version: 20260107
Requires: absl_algorithm_container = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_flags_config = 20260107, absl_flags = 20260107, absl_flags_commandlineflag = 20260107, absl_flags_commandlineflag_internal = 20260107, absl_flags_internal = 20260107, absl_flags_private_handle_accessor = 20260107, absl_flags_program_name = 20260107, absl_flags_reflection = 20260107, absl_flags_usage = 20260107, absl_no_destructor = 20260107, absl_strings = 20260107, absl_synchronization = 20260107
Libs: -L${libdir}  -labsl_flags_parse 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
