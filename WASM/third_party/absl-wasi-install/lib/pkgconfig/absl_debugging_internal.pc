prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_debugging_internal
Description: Abseil debugging_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_core_headers = 20260107, absl_config = 20260107, absl_dynamic_annotations = 20260107, absl_errno_saver = 20260107, absl_raw_logging_internal = 20260107
Libs: -L${libdir}  -labsl_debugging_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
