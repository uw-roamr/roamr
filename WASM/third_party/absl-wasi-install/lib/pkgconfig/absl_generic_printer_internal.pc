prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_generic_printer_internal
Description: Abseil generic_printer_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_strings = 20260107, absl_str_format = 20260107, absl_log_internal_container = 20260107, absl_requires_internal = 20260107
Libs: -L${libdir}  -labsl_generic_printer_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
