prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_linked_hash_map
Description: Abseil linked_hash_map library
URL: https://abseil.io/
Version: 20260107
Requires: absl_container_common = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_flat_hash_set = 20260107, absl_throw_delegate = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
