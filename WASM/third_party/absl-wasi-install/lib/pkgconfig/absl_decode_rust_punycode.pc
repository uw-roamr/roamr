prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_decode_rust_punycode
Description: Abseil decode_rust_punycode library
URL: https://abseil.io/
Version: 20260107
Requires: absl_bounded_utf8_length_sequence = 20260107, absl_config = 20260107, absl_nullability = 20260107, absl_utf8_for_code_point = 20260107
Libs: -L${libdir}  -labsl_decode_rust_punycode 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
