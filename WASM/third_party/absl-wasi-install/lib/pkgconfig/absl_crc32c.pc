prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_crc32c
Description: Abseil crc32c library
URL: https://abseil.io/
Version: 20260107
Requires: absl_crc_cpu_detect = 20260107, absl_crc_internal = 20260107, absl_non_temporal_memcpy = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_endian = 20260107, absl_prefetch = 20260107, absl_str_format = 20260107, absl_strings = 20260107
Libs: -L${libdir}  -labsl_crc32c 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
