prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_random_random
Description: Abseil random_random library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_random_distributions = 20260107, absl_random_internal_nonsecure_base = 20260107, absl_random_internal_pcg_engine = 20260107, absl_random_internal_randen_engine = 20260107, absl_random_seed_sequences = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
