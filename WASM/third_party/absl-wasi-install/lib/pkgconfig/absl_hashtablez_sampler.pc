prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_hashtablez_sampler
Description: Abseil hashtablez_sampler library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_config = 20260107, absl_exponential_biased = 20260107, absl_no_destructor = 20260107, absl_raw_logging_internal = 20260107, absl_sample_recorder = 20260107, absl_synchronization = 20260107, absl_time = 20260107
Libs: -L${libdir}  -labsl_hashtablez_sampler 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
