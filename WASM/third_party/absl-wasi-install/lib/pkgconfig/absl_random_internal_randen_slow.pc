prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_random_internal_randen_slow
Description: Abseil random_internal_randen_slow library
URL: https://abseil.io/
Version: 20260107
Requires: absl_random_internal_platform = 20260107, absl_config = 20260107
Libs: -L${libdir}  -labsl_random_internal_randen_slow 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
