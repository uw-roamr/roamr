prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_log_internal_check_op
Description: Abseil log_internal_check_op library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_has_ostream_operator = 20260107, absl_leak_check = 20260107, absl_log_internal_nullguard = 20260107, absl_log_internal_nullstream = 20260107, absl_log_internal_strip = 20260107, absl_nullability = 20260107, absl_strings = 20260107
Libs: -L${libdir}  -labsl_log_internal_check_op 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
