prefix=/src/third_party/protobuf-wasi-install
exec_prefix=/src/third_party/protobuf-wasi-install
libdir=/src/third_party/protobuf-wasi-install/lib
includedir=/src/third_party/protobuf-wasi-install/include

Name: UTF8 Range
Description: Google's UTF8 Library
Version: 1.0
Requires: absl_strings
Libs: -L${libdir} -lutf8_validity -lutf8_range -lpthread
Cflags: -I${includedir}
